  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MateriAlatMove
  kotakPenjelasan: {fileID: 274683462}
  gambarAlat: {fileID: 1456592607}
  komponenTeks: {fileID: 439698975}
  daftarHalaman:
  - "Fungsi Utama: \nMengupas kulit luar (jaket pelindung) kabel UTP tanpa merusak
    kawat di dalamnya.\n\nCara Kerja: \nAlat ini dilengkapi mata pisau yang presisi.
    Kamu cukup memasukkan kabel, memutar alat ini satu putaran, dan jaket luar kabel
    akan terpotong dengan rapi."
  - "Pro-Tip Instalasi: \nJangan menekan alat ini terlalu dalam! Jika kawat tembaga
    kecil di bagian dalam ikut tergores atau terpotong, kabel berisiko mengalami
    gagal fungsi atau short (korsleting data)."
  tombolPrev: {fileID: 1702410031}
  tombolNext: {fileID: 1890763561}
  posisiY_Tengah: 0
  posisiY_Atas: 145
  durasiGerak: 0.3
